  transition:all .3s;animation:pgr 3s infinite;}
.btn-wa:hover{transform:translateY(-2px);}
@keyframes pgr{0%,100%{box-shadow:0 4px 16px rgba(37,211,102,.3)}50%{box-shadow:0 4px 28px rgba(37,211,102,.6)}}
.btn-outline-w{display:flex;align-items:center;gap:8px;
  border:1.5px solid rgba(255,255,255,.25);color:rgba(255,255,255,.8);
  padding:13px 22px;border-radius:12px;font-weight:500;font-size:.88rem;transition:all .3s;}
.btn-outline-w:hover{border-color:rgba(255,255,255,.5);background:rgba(255,255,255,.05);}
