.nav-back:hover{color:var(--teal);border-color:var(--teal);}
.nav-cta{background:var(--teal);color:white;padding:9px 20px;border-radius:10px;
  font-size:.8rem;font-weight:700;transition:all .3s;box-shadow:var(--shadow);}
.nav-cta:hover{background:var(--teal-light);transform:translateY(-1px);}

/* ── HERO ── */
