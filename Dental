  color:#fca5a5;padding:8px 16px;border-radius:8px;font-size:.78rem;font-weight:500;}
.blink{animation:bl 1.2s infinite;}
@keyframes bl{0%,100%{opacity:1}50%{opacity:.3}}

/* Hero right card */
.hero-card{background:rgba(255,255,255,.06);backdrop-filter:blur(20px);
