<style>
/* ── TOKENS ── */
:root{
  --teal:#0a6b6b; --teal-light:#0d8a8a; --teal-pale:#e8f5f5;
  --navy:#0a1628; --navy-mid:#163252;
  --gold:#b8963e; --gold-light:#d4ae5a; --gold-pale:#fdf8ee;
  --mint:#f0fafa; --white:#ffffff; --off:#f8fafb;
  --gray:#64748b; --gray-light:#e2e8f0; --text:#1e293b;
  --green:#25D366; --red:#ef4444;
  --shadow:0 4px 24px rgba(10,107,107,.1);
  --shadow-lg:0 12px 48px rgba(10,107,107,.15);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--white);color:var(--text);overflow-x:hidden;}
a{text-decoration:none;}
img{max-width:100%;display:block;}

/* ── TICKER ── */
.ticker{background:var(--teal);height:38px;overflow:hidden;}
.ticker-track{display:flex;align-items:center;height:100%;animation:tk 28s linear infinite;white-space:nowrap;}
.ticker-track:hover{animation-play-state:paused;}
.ti{display:inline-flex;align-items:center;gap:8px;padding:0 28px;font-size:.76rem;font-weight:500;color:rgba(255,255,255,.9);letter-spacing:.03em;}
.ts{color:rgba(255,255,255,.4);}
@keyframes tk{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ── NAV ── */
.nav{position:fixed;top:38px;left:0;right:0;z-index:1000;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 5%;height:72px;background:rgba(255,255,255,.97);
  backdrop-filter:blur(20px);border-bottom:1px solid transparent;
  transition:all .3s;box-shadow:none;}
.nav.scrolled{top:0;border-bottom-color:var(--gray-light);box-shadow:0 2px 20px rgba(10,107,107,.08);}
.logo-wrap{display:flex;align-items:center;gap:14px;}
.logo-icon{width:46px;height:46px;background:linear-gradient(135deg,var(--teal),var(--teal-light));
  border-radius:12px;display:flex;align-items:center;justify-content:center;
  font-family:'DM Serif Display',serif;font-size:1.1rem;color:white;flex-shrink:0;}
.logo-name{font-family:'DM Serif Display',serif;font-size:1.05rem;color:var(--navy);display:block;line-height:1.2;}
.logo-sub{font-size:.63rem;color:var(--teal);font-weight:600;letter-spacing:.08em;text-transform:uppercase;}
.nav-links{display:flex;align-items:center;gap:6px;}
.nav-links a{color:var(--gray);font-size:.82rem;font-weight:500;padding:7px 14px;border-radius:8px;transition:all .2s;}
.nav-links a:hover{color:var(--teal);background:var(--teal-pale);}
.nav-right{display:flex;align-items:center;gap:10px;}
.nav-back{display:flex;align-items:center;gap:6px;color:var(--gray);font-size:.76rem;font-weight:500;
